prefix=E:/samsung-ennovatex-project/assistant/Library
includedir=${prefix}/include
libdir=${prefix}/lib

sysconfdir=E:/samsung-ennovatex-project/assistant/Library/etc
localstatedir=E:/samsung-ennovatex-project/assistant/Library/var
confdir=E:/samsung-ennovatex-project/assistant/Library/etc/fonts
cachedir=LOCAL_APPDATA_FONTCONFIG_CACHE

Name: Fontconfig
Description: Font configuration and customization library
Version: 2.17.1
Requires.private: freetype2 >=  21.0.15
Libs: -L${libdir} -lfontconfig
Libs.private: E:/samsung-ennovatex-project/assistant/Library/lib/expat.lib E:/samsung-ennovatex-project/assistant/Library/lib/expat.lib
Cflags: -I${includedir}
