libdir=E:/samsung-ennovatex-project/assistant/lib
includedir=E:/samsung-ennovatex-project/assistant/include

Name: mpc
URL: https://www.multiprecision.org/
Description: A C library for the arithmetic of complex numbers with arbitrarily high precision.
Version: 1.3.1
Libs: -L${libdir} -lmpc -lmpfr -lgmp
Cflags: -I${includedir}
